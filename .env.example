# MS2GO Sales Command Center — server-side function secrets
# All of these are set in Netlify production. None ship to the client bundle.

# Google Places (Places Search + Details). Server-side only.
GOOGLE_PLACES_API_KEY=

# DataForSEO (Basic Auth). Server-side only.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# OpenAI. Server-side only.
OPENAI_API_KEY=

# Calendly (optional, used by booking views).
CALENDLY_PERSONAL_ACCESS_TOKEN=

# Resend transactional email. Optional until domain verification completes.
RESEND_API_KEY=

# Branded sender identity for outbound messages.
# Defaults: from = sales@ms2go.com, reply-to = joe@ms2go.com
MS2GO_FROM_EMAIL=
MS2GO_REPLY_TO=
