# MS2GO Sales Command Center — server-side function secrets
# All of these are set in Netlify production. None ship to the client bundle.

# Supabase — server-side keys (Netlify Functions).
SUPABASE_URL=https://izoveptctxypwmyvavyg.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — browser-side public keys (Vite).
VITE_SUPABASE_URL=https://izoveptctxypwmyvavyg.supabase.co
VITE_SUPABASE_ANON_KEY=

# Google Places (Places Search + Details). Server-side only.
GOOGLE_PLACES_API_KEY=

# DataForSEO (Basic Auth). Server-side only.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# OpenAI. Server-side only.
OPENAI_API_KEY=

# Calendly (optional, used by booking views).
CALENDLY_PERSONAL_ACCESS_TOKEN=

# Resend transactional email. Optional until domain verification completes.
RESEND_API_KEY=

# Branded sender identity for outbound messages.
# Defaults: from = sales@ms2go.com, reply-to = joe@mstogo.com
MS2GO_FROM_EMAIL=
MS2GO_REPLY_TO=

# Dropbox Sign (formerly HelloSign). Used by the account callback at
# /.netlify/functions/dropbox-sign-callback to verify event hashes.
# When present, incoming callbacks have their event_hash checked via HMAC-SHA256.
DROPBOX_SIGN_API_KEY=

# Plaid (contractor payout / direct-deposit onboarding). Used by:
#   /.netlify/functions/plaid-create-link-token  (creates a Plaid Link token)
#   /.netlify/functions/plaid-exchange-token     (exchanges public token,
#                                                 fetches auth + identity,
#                                                 returns safe summary only)
# Required products: auth, identity. Country: US. Language: en.
# PLAID_ENV ∈ { sandbox, development, production } selects the Plaid host:
#   sandbox     -> https://sandbox.plaid.com
#   development -> https://development.plaid.com
#   production  -> https://production.plaid.com
# Secrets stay server-side; the browser only ever sees a short-lived link_token
# and a verification summary (last4 mask, institution, owner match, status).
# Sandbox test creds inside Plaid Link: username "user_good" / password
# "pass_good".
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Gusto OAuth + webhook. Used by:
#   /gusto/oauth/callback        (branded app route, handles ?code/?error)
#   /.netlify/functions/gusto-webhook  (subscription event receiver)
# When GUSTO_WEBHOOK_SECRET is set, incoming webhook bodies are verified via
# HMAC-SHA256 against the X-Gusto-Signature header.
GUSTO_CLIENT_ID=
GUSTO_CLIENT_SECRET=
GUSTO_WEBHOOK_SECRET=
